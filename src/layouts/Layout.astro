---
import '../styles/global.css';
import '@fontsource-variable/inter';
import CookieBanner from '../components/layout/CookieBanner.astro';

interface Props {
  title: string;
  description: string;
  canonical: string;
  ogImage?: string;
  schema?: object;
  noIndex?: boolean;
}
const {
  title,
  description,
  canonical,
  ogImage = '/og-image.png',
  schema,
  noIndex,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, minimum-scale=1" />
    <meta name="theme-color" content="#6366f1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.svg" />
    <meta name="msapplication-TileColor" content="#6366f1" />


    <!-- SEO meta -->
    <title>{title}</title>
    <meta name="description" content={description.slice(0, 160)} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description.slice(0, 160)} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Fontoza" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description.slice(0, 160)} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Robots -->
    {noIndex && <meta name="robots" content="noindex, nofollow" />}

    <!-- JSON-LD schema -->
    {schema && <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />}

    <!-- Dark mode: apply .dark BEFORE body renders to prevent flash -->
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem('fontoza-theme');
          if (stored === 'dark' || (!stored && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
          }
        } catch (e) {}

        window.__toggleTheme = function () {
          var isDark = document.documentElement.classList.toggle('dark');
          try {
            localStorage.setItem('fontoza-theme', isDark ? 'dark' : 'light');
          } catch (e) {}
        };
      })();
    </script>

    <slot name="head" />
  </head>

  <body class="min-h-screen bg-[var(--color-bg)] text-[var(--color-text)] antialiased">
    <!-- Skip to content for accessibility -->
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:rounded-md focus:bg-indigo-600 focus:px-4 focus:py-2 focus:text-white focus:outline-none"
    >
      Skip to content
    </a>

    <slot />

    <CookieBanner />

    <!-- ✨ Eye-candy: cursor glow + sparkle burst + ripple + card tilt -->
    <div id="cursor-glow" aria-hidden="true"></div>

    <script is:inline>
      (function () {
        /* ── Cursor glow (desktop) ── */
        var glow = document.getElementById('cursor-glow');
        var isTouchDevice = window.matchMedia('(pointer: coarse)').matches;
        var reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        if (glow && !isTouchDevice && !reduceMotion) {
          var glowX = 0, glowY = 0, curX = 0, curY = 0;
          glow.style.opacity = '1';
          glow.style.transform = 'translate(-50%, -50%) scale(1)';
          document.addEventListener('mousemove', function (e) {
            curX = e.clientX; curY = e.clientY;
          });
          (function loop() {
            glowX += (curX - glowX) * 0.08;
            glowY += (curY - glowY) * 0.08;
            glow.style.left = glowX + 'px';
            glow.style.top  = glowY + 'px';
            requestAnimationFrame(loop);
          })();
        }

        /* ── Sparkle burst on any copy action ── */
        var SPARKLES = ['✨','⭐','💫','🌟','✦','◆','❋'];
        function burst(x, y) {
          if (reduceMotion) return;
          for (var i = 0; i < 8; i++) {
            var el = document.createElement('span');
            el.className = 'sparkle-particle';
            el.textContent = SPARKLES[i % SPARKLES.length];
            var angle = (i / 8) * 360;
            var dist = 40 + Math.random() * 40;
            var tx = Math.cos(angle * Math.PI / 180) * dist;
            var ty = Math.sin(angle * Math.PI / 180) * dist;
            el.style.left = x + 'px';
            el.style.top  = y + 'px';
            el.style.setProperty('--tx', tx + 'px');
            el.style.setProperty('--ty', ty + 'px');
            el.style.transform = 'translate(-50%,-50%)';
            el.style.animationDelay = (i * 0.04) + 's';
            document.body.appendChild(el);
            setTimeout(function () { if (el.parentNode) el.parentNode.removeChild(el); }, 900);
          }
        }
        document.addEventListener('click', function (e) {
          var btn = e.target.closest('[data-copy-btn],[aria-label*="Copy"],[aria-label*="copy"]');
          if (btn) burst(e.clientX, e.clientY);
        });

        /* ── Ripple on card/button clicks ── */
        document.addEventListener('click', function (e) {
          var target = e.target.closest('a[href],button,.card-hover');
          if (!target || reduceMotion) return;
          var rect = target.getBoundingClientRect();
          var ripple = document.createElement('span');
          ripple.className = 'ripple-effect';
          ripple.style.left = (e.clientX - rect.left) + 'px';
          ripple.style.top  = (e.clientY - rect.top)  + 'px';
          var pos = window.getComputedStyle(target).position;
          if (pos === 'static') target.style.position = 'relative';
          target.style.overflow = 'hidden';
          target.appendChild(ripple);
          setTimeout(function () { if (ripple.parentNode) ripple.parentNode.removeChild(ripple); }, 700);
        });

        /* ── 3D card tilt on .tilt-card elements ── */
        if (!isTouchDevice && !reduceMotion) {
          document.querySelectorAll('.card-hover').forEach(function (card) {
            card.addEventListener('mousemove', function (e) {
              var rect = card.getBoundingClientRect();
              var cx = rect.left + rect.width / 2;
              var cy = rect.top + rect.height / 2;
              var rx = ((e.clientY - cy) / (rect.height / 2)) * -5;
              var ry = ((e.clientX - cx) / (rect.width / 2)) * 5;
              card.style.transform = 'translateY(-2px) perspective(600px) rotateX(' + rx + 'deg) rotateY(' + ry + 'deg)';
            });
            card.addEventListener('mouseleave', function () {
              card.style.transform = '';
            });
          });
        }
      })();
    </script>

    <!-- Scroll-reveal: IntersectionObserver watches [data-scroll] elements -->
    <script is:inline>
      (function () {
        if (typeof IntersectionObserver === 'undefined') return;
        var observer = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add('scroll-visible');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.12, rootMargin: '0px 0px -48px 0px' }
        );
        function observe() {
          document.querySelectorAll('[data-scroll]').forEach(function (el) {
            observer.observe(el);
          });
        }
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', observe);
        } else {
          observe();
        }
      })();
    </script>

    <!-- Vercel Analytics — production only -->
    {import.meta.env.PROD && (
      <script is:inline defer src="/_vercel/insights/script.js"></script>
    )}
  </body>
</html>
