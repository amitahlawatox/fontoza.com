---
import Layout from '../layouts/Layout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import AdSlot from '../components/ads/AdSlot.astro';
import FontConverter from '../components/tool/FontConverter';
import { STYLES } from '../lib/registry';
import type { StyleDefinition } from '../lib/registry';
import { CATEGORIES } from '../lib/categories';
import { getHomeMeta } from '../lib/seo/meta';
import { webSiteSchema, webApplicationSchema } from '../lib/seo/schema';

const meta = getHomeMeta();

const schema = [
  webSiteSchema(),
  webApplicationSchema({
    name: 'Fontoza — Fancy Text Generator',
    description: meta.description,
    url: 'https://fontoza.com',
  }),
];

function getDecoratorName(style: StyleDefinition): string | undefined {
  if (style.decoratorName) return style.decoratorName;
  if (style.id.includes('strikethrough') || style.tags?.includes('strikethrough')) return 'strikethrough';
  if (style.id.includes('double-underline')) return 'doubleUnderline';
  if (style.id.includes('underline') && !style.id.includes('double')) return 'underline';
  if (style.id.includes('zalgo-light')) return 'zalgoLight';
  if (style.id.includes('zalgo-heavy')) return 'zalgoHeavy';
  if (style.id.includes('zalgo')) return 'zalgoMedium';
  if (style.id.includes('vaporwave')) return 'vaporwaveSpace';
  if (style.id.includes('hearts') || style.tags?.includes('hearts')) return 'hearts';
  if (style.id.includes('stars') || style.tags?.includes('stars')) return 'stars';
  if (style.id.includes('sparkles') || style.tags?.includes('sparkles')) return 'sparkles';
  if (style.id.includes('flowers') || style.tags?.includes('flowers')) return 'flowers';
  if (style.id.includes('crown') || style.tags?.includes('crown')) return 'crown';
  if (style.id.endsWith('-fire')) return 'fire';
  if (style.id.endsWith('-moon')) return 'moon';
  if (style.id.endsWith('-music')) return 'music';
  if (style.id.endsWith('-butterfly')) return 'butterfly';
  if (style.id.endsWith('-lightning')) return 'lightning';
  if (style.id.endsWith('-rainbow')) return 'rainbow';
  if (style.id.endsWith('-diamond')) return 'diamond';
  if (style.id.endsWith('-rose')) return 'rose';
  return undefined;
}

const serializedStyles = STYLES.map((style) => ({
  id: style.id,
  name: style.name,
  map: style.map as Record<string, string>,
  category: style.category,
  decorator: getDecoratorName(style),
}));

const homeFaqs = [
  {
    q: 'What is a fancy text generator?',
    a: 'A fancy text generator converts regular letters into Unicode characters that look like different fonts — cursive, bold, gothic, and more. Because these are real Unicode characters (not custom fonts), they display identically on every device and paste directly into any app or website.',
  },
  {
    q: 'Why does the fancy text work on Instagram and TikTok?',
    a: 'Instagram, TikTok, Twitter, and most other platforms support the full Unicode standard. The "fancy" characters here come from Unicode mathematical and symbol blocks — they are standard characters that every modern device can display, not images or special fonts.',
  },
  {
    q: 'Is Fontoza free to use?',
    a: 'Yes, Fontoza is completely free. No account, no subscription, and no download is required. Just type your text, pick a style, and copy it.',
  },
  {
    q: 'How many font styles does Fontoza have?',
    a: 'Fontoza offers 400+ Unicode font styles including cursive, bold, italic, gothic, small caps, vaporwave, zalgo, and many more. Each style is generated in real time as you type.',
  },
  {
    q: 'Do the fancy fonts work on mobile devices?',
    a: 'Yes. Unicode characters display correctly on all modern smartphones running iOS or Android. You can generate text on your phone, copy it, and paste it directly into your apps.',
  },
];

const floatingChars = ['𝒻', '𝔉', '𝐅', 'Ｆ', '𝓕', '𝙁', '𝔽', 'ℱ'];
const platformBadges = [
  { name: 'Instagram', color: 'from-pink-500 to-orange-400' },
  { name: 'TikTok', color: 'from-slate-900 to-slate-700 dark:from-slate-100 dark:to-slate-300' },
  { name: 'Discord', color: 'from-indigo-500 to-blue-500' },
  { name: 'Twitter/X', color: 'from-sky-500 to-blue-600' },
  { name: 'WhatsApp', color: 'from-green-500 to-emerald-600' },
  { name: 'YouTube', color: 'from-red-500 to-rose-600' },
];
---

<Layout
  title={meta.title}
  description={meta.description}
  canonical={meta.canonical}
  ogImage={meta.ogImage}
  schema={schema}
>
  <Header />

  <main id="main-content">

    <!-- ══════════════════════════════════════════════
         HERO SECTION — full Gen Z energy
    ══════════════════════════════════════════════ -->
    <section class="relative overflow-hidden py-14 sm:py-18">

      <!-- Animated background mesh gradient -->
      <div class="pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
        <div class="absolute -top-40 -right-40 w-[600px] h-[600px] rounded-full bg-gradient-to-br from-indigo-400/15 to-purple-400/10 blur-3xl animate-float"></div>
        <div class="absolute -bottom-40 -left-40 w-[500px] h-[500px] rounded-full bg-gradient-to-br from-pink-400/10 to-indigo-400/10 blur-3xl animate-float-delay-2"></div>
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[400px] rounded-full bg-gradient-to-r from-indigo-500/5 via-purple-500/5 to-pink-500/5 blur-3xl"></div>
      </div>

      <!-- Floating unicode characters (decorative) -->
      <div class="pointer-events-none absolute inset-0 overflow-hidden select-none" aria-hidden="true">
        {floatingChars.map((char, i) => (
          <span
            class={`absolute text-3xl font-black opacity-[0.04] dark:opacity-[0.06] animate-float-delay-${i % 4}`}
            style={`top: ${10 + (i * 11) % 70}%; left: ${5 + (i * 13) % 90}%; animation-duration: ${5 + (i % 3)}s;`}
          >
            {char}
          </span>
        ))}
      </div>

      <div class="relative mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">

        <!-- Platform badges strip -->
        <div class="mb-8 flex flex-wrap justify-center gap-2 animate-fade-up">
          {platformBadges.map(badge => (
            <span class={`inline-flex items-center rounded-full bg-gradient-to-r ${badge.color} px-3 py-1 text-xs font-bold text-white shadow-sm`}>
              {badge.name}
            </span>
          ))}
        </div>

        <!-- Main headline -->
        <div class="mb-6 text-center animate-fade-up-delay-1">
          <h1 class="text-4xl font-black tracking-tight text-[var(--color-text)] sm:text-5xl lg:text-6xl leading-tight">
            Make Your Text
            <br class="hidden sm:block" />
            <span class="text-shimmer">Actually Glow ✨</span>
          </h1>
          <p class="mt-5 mx-auto max-w-xl text-base text-[var(--color-text-muted)] sm:text-lg leading-relaxed">
            400+ Unicode font styles that copy & paste into <strong class="text-[var(--color-text)]">Instagram, TikTok, Discord</strong> and everywhere else. No app, no sign-up.
          </p>
        </div>

        <!-- Stats strip -->
        <div class="mb-8 flex flex-wrap justify-center gap-6 text-center animate-fade-up-delay-2">
          <div>
            <div class="text-2xl font-black text-[var(--color-text)] stat-number glow">{STYLES.length}+</div>
            <div class="text-xs text-[var(--color-text-muted)]">Font Styles</div>
          </div>
          <div class="w-px bg-[var(--color-border)]"></div>
          <div>
            <div class="text-2xl font-black text-[var(--color-text)] stat-number">100%</div>
            <div class="text-xs text-[var(--color-text-muted)]">Free Forever</div>
          </div>
          <div class="w-px bg-[var(--color-border)]"></div>
          <div>
            <div class="text-2xl font-black text-[var(--color-text)] stat-number">0</div>
            <div class="text-xs text-[var(--color-text-muted)]">Sign-ups Needed</div>
          </div>
          <div class="w-px bg-[var(--color-border)]"></div>
          <div>
            <div class="text-2xl font-black text-[var(--color-text)] stat-number">12</div>
            <div class="text-xs text-[var(--color-text-muted)]">Platforms</div>
          </div>
        </div>

        <!-- THE TOOL — center stage -->
        <div class="animate-fade-up-delay-3">
          <div class="rounded-3xl border border-[var(--color-border)] bg-[var(--color-bg)] p-6 shadow-2xl shadow-indigo-500/5 sm:p-8"
               style="box-shadow: 0 32px 80px rgba(99,102,241,0.08), 0 4px 16px rgba(0,0,0,0.06);">
            <FontConverter client:load styles={serializedStyles} />
          </div>
        </div>

      </div>
    </section>

    <!-- ══════════════════════════════════════════════
         MARQUEE — infinite scrolling font preview
    ══════════════════════════════════════════════ -->
    <div class="marquee-section relative overflow-hidden border-y border-[var(--color-border)] bg-[var(--color-surface)] py-4" aria-hidden="true">
      <!-- Fade edges -->
      <div class="pointer-events-none absolute left-0 top-0 bottom-0 w-20 z-10 bg-gradient-to-r from-[var(--color-surface)] to-transparent"></div>
      <div class="pointer-events-none absolute right-0 top-0 bottom-0 w-20 z-10 bg-gradient-to-l from-[var(--color-surface)] to-transparent"></div>
      <div class="marquee-track flex gap-8 whitespace-nowrap">
        {['𝒞𝓊𝓇𝓈𝒾𝓋𝑒','𝔊𝔬𝔱𝔥𝔦𝔠','𝐁𝐨𝐥𝐝','𝕯𝖔𝖚𝖇𝖑𝖊','ⓒⓘⓡⓒⓛⓔⓓ','ａｅｓｔｈｅｔｉｃ','𝙼𝚘𝚗𝚘','𝓑𝓸𝓵𝓭 𝓒𝓾𝓻𝓼𝓲𝓿𝓮','ꜱᴍᴀʟʟ ᴄᴀᴘꜱ','🔥 𝐅𝐢𝐫𝐞 🔥','⚡ 𝔹𝕠𝕝𝕕 ⚡','✨ 𝒮𝓅𝒶𝓇𝓀𝓁𝑒𝓈 ✨','♛ 𝕮𝖗𝖔𝖜𝖓 ♛','𝙂𝙤𝙩𝙝𝙞𝙘','🌙 𝓜𝓸𝓸𝓷 🌙','𝒞𝓊𝓇𝓈𝒾𝓋𝑒','𝔊𝔬𝔱𝔥𝔦𝔠','𝐁𝐨𝐥𝐝','𝕯𝖔𝖚𝖇𝖑𝖊','ⓒⓘⓡⓒⓛⓔⓓ','ａｅｓｔｈｅｔｉｃ','𝙼𝚘𝚗𝚘','𝓑𝓸𝓵𝓭 𝓒𝓾𝓻𝓼𝓲𝓿𝓮','ꜱᴍᴀʟʟ ᴄᴀᴘꜱ','🔥 𝐅𝐢𝐫𝐞 🔥','⚡ 𝔹𝕠𝕝𝕕 ⚡','✨ 𝒮𝓅𝒶𝓇𝓀𝓁𝑒𝓈 ✨','♛ 𝕮𝖗𝖔𝖜𝖓 ♛','𝙂𝙤𝙩𝙝𝙞𝙘','🌙 𝓜𝓸𝓸𝓷 🌙'].map(text => (
          <span class="marquee-item text-lg font-semibold text-[var(--color-text-muted)] opacity-70 select-none">{text}</span>
        ))}
      </div>
    </div>

    <!-- ══════════════════════════════════════════════
         HOW IT WORKS — 3 steps with icons
    ══════════════════════════════════════════════ -->
    <section class="py-16 bg-[var(--color-surface)]">
      <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
        <h2 data-scroll="fade-up" class="mb-12 text-center text-2xl font-black text-[var(--color-text)] sm:text-3xl">
          Three steps, zero effort
        </h2>
        <div data-scroll="stagger-up" class="grid gap-6 sm:grid-cols-3">

          <div class="relative rounded-3xl border border-[var(--color-border)] bg-[var(--color-bg)] p-6 text-center overflow-hidden group hover:border-indigo-300 transition-all">
            <div class="pointer-events-none absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity rounded-3xl" style="background: radial-gradient(ellipse at center top, rgba(99,102,241,0.06) 0%, transparent 60%);" aria-hidden="true"></div>
            <div class="relative mb-4 mx-auto flex h-16 w-16 items-center justify-center rounded-2xl bg-gradient-to-br from-indigo-100 to-indigo-50 dark:from-indigo-900/60 dark:to-indigo-800/30 text-3xl shadow-sm">
              ✏️
            </div>
            <div class="absolute top-4 right-4 flex h-7 w-7 items-center justify-center rounded-full bg-indigo-100 dark:bg-indigo-900/50 text-xs font-black text-indigo-600 dark:text-indigo-400">1</div>
            <h3 class="mb-2 text-lg font-bold text-[var(--color-text)]">Type</h3>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">
              Enter any text. All 400+ font styles update <em>instantly</em> as you type.
            </p>
          </div>

          <div class="relative rounded-3xl border border-[var(--color-border)] bg-[var(--color-bg)] p-6 text-center overflow-hidden group hover:border-purple-300 transition-all">
            <div class="pointer-events-none absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity rounded-3xl" style="background: radial-gradient(ellipse at center top, rgba(168,85,247,0.06) 0%, transparent 60%);" aria-hidden="true"></div>
            <div class="relative mb-4 mx-auto flex h-16 w-16 items-center justify-center rounded-2xl bg-gradient-to-br from-purple-100 to-purple-50 dark:from-purple-900/60 dark:to-purple-800/30 text-3xl shadow-sm">
              🎨
            </div>
            <div class="absolute top-4 right-4 flex h-7 w-7 items-center justify-center rounded-full bg-purple-100 dark:bg-purple-900/50 text-xs font-black text-purple-600 dark:text-purple-400">2</div>
            <h3 class="mb-2 text-lg font-bold text-[var(--color-text)]">Pick</h3>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">
              Scroll through cursive, gothic, vaporwave, zalgo & more. Find your vibe.
            </p>
          </div>

          <div class="relative rounded-3xl border border-[var(--color-border)] bg-[var(--color-bg)] p-6 text-center overflow-hidden group hover:border-pink-300 transition-all">
            <div class="pointer-events-none absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity rounded-3xl" style="background: radial-gradient(ellipse at center top, rgba(236,72,153,0.06) 0%, transparent 60%);" aria-hidden="true"></div>
            <div class="relative mb-4 mx-auto flex h-16 w-16 items-center justify-center rounded-2xl bg-gradient-to-br from-pink-100 to-pink-50 dark:from-pink-900/60 dark:to-pink-800/30 text-3xl shadow-sm">
              📋
            </div>
            <div class="absolute top-4 right-4 flex h-7 w-7 items-center justify-center rounded-full bg-pink-100 dark:bg-pink-900/50 text-xs font-black text-pink-600 dark:text-pink-400">3</div>
            <h3 class="mb-2 text-lg font-bold text-[var(--color-text)]">Copy & Paste</h3>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">
              Hit copy. Paste anywhere — Instagram, TikTok, Discord, Twitter, iMessage.
            </p>
          </div>

        </div>
      </div>
    </section>

    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 py-4">
      <AdSlot slot="mid" />
    </div>

    <!-- ══════════════════════════════════════════════
         BROWSE BY CATEGORY
    ══════════════════════════════════════════════ -->
    <section class="py-16">
      <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
        <div data-scroll="fade-up" class="mb-10 text-center">
          <h2 class="text-2xl font-black text-[var(--color-text)] sm:text-3xl">Browse by Category</h2>
          <p class="mt-2 text-sm text-[var(--color-text-muted)]">7 curated style families. Find your aesthetic.</p>
        </div>
        <div data-scroll="stagger-up" class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
          {CATEGORIES.map((cat) => (
            <a
              href={`/category/${cat.id}/`}
              class="card-hover group relative flex items-start gap-3 rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg)] p-5 overflow-hidden"
            >
              <div class="pointer-events-none absolute inset-0 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity" style="background: radial-gradient(ellipse at top left, rgba(99,102,241,0.06) 0%, transparent 60%);" aria-hidden="true"></div>
              <span class="text-2xl flex-shrink-0" aria-hidden="true">{cat.icon}</span>
              <div class="min-w-0 relative">
                <span class="block font-bold text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors truncate">
                  {cat.name}
                </span>
                <span class="mt-1 block text-xs text-[var(--color-text-muted)] line-clamp-2 leading-relaxed">
                  {cat.description}
                </span>
                <span class="mt-2 block text-xs font-semibold text-indigo-500">
                  {cat.styleIds.length} styles
                </span>
              </div>
            </a>
          ))}
        </div>
        <div data-scroll="fade-up" class="mt-8 text-center">
          <a href="/fonts/" class="inline-flex items-center gap-2 rounded-2xl border border-indigo-200 bg-indigo-50 px-6 py-3 text-sm font-bold text-indigo-700 transition-all hover:bg-indigo-100 hover:scale-[1.02] dark:border-indigo-800/50 dark:bg-indigo-900/30 dark:text-indigo-300 dark:hover:bg-indigo-900/50">
            View all {STYLES.length}+ font styles
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════════
         WHY FONTOZA — trust signals
    ══════════════════════════════════════════════ -->
    <section class="py-16 bg-[var(--color-surface)]">
      <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
        <h2 data-scroll="fade-up" class="mb-10 text-center text-2xl font-black text-[var(--color-text)] sm:text-3xl">Why Fontoza?</h2>
        <ul data-scroll="stagger-up" class="space-y-4">
          {[
            { icon: '🚀', title: 'No sign-up required.', body: 'Open the page and start generating. No email, no account, no nonsense.' },
            { icon: '📱', title: 'Works everywhere.', body: 'Instagram, TikTok, Discord, Twitter, Facebook, WhatsApp, YouTube — every platform renders Unicode text.' },
            { icon: '💅', title: 'Mobile-first design.', body: 'Built for touch screens. Generate and copy on your phone in 3 seconds flat.' },
            { icon: '✨', title: '400+ font styles.', body: 'Cursive, bold, gothic, italic, vaporwave, zalgo, geometric, transform styles — widest selection, one place.' },
            { icon: '🔒', title: 'Zero tracking.', body: 'No cookies, no personal data, no ads that follow you. Your text never leaves your device.' },
          ].map(item => (
            <li class="flex items-start gap-4 rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg)] p-5 transition-all hover:border-indigo-200 dark:hover:border-indigo-800/50">
              <span class="mt-0.5 flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-xl bg-gradient-to-br from-indigo-100 to-purple-100 text-xl dark:from-indigo-900/50 dark:to-purple-900/50">
                {item.icon}
              </span>
              <div>
                <span class="font-bold text-[var(--color-text)]">{item.title}</span>
                <span class="ml-1 text-sm text-[var(--color-text-muted)]">{item.body}</span>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- ══════════════════════════════════════════════
         TOOLS ROW
    ══════════════════════════════════════════════ -->
    <section class="py-16">
      <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
        <div data-scroll="fade-up" class="mb-10 text-center">
          <h2 class="text-2xl font-black text-[var(--color-text)] sm:text-3xl">More Free Tools</h2>
          <p class="mt-2 text-sm text-[var(--color-text-muted)]">Everything you need, right in your browser.</p>
        </div>
        <div data-scroll="stagger-up" class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
          {[
            { href: '/tools/word-counter/', icon: '📝', name: 'Word Counter', desc: 'Words, chars, sentences' },
            { href: '/tools/password-generator/', icon: '🔐', name: 'Password Generator', desc: 'Cryptographically secure' },
            { href: '/tools/bio-generator/', icon: '✨', name: 'Bio Generator', desc: 'Instagram & TikTok bios' },
            { href: '/tools/hashtag-generator/', icon: '#️⃣', name: 'Hashtag Generator', desc: '30 relevant hashtags' },
          ].map(tool => (
            <a href={tool.href} class="card-hover group flex items-start gap-3 rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg)] p-4 transition-all">
              <span class="text-2xl flex-shrink-0">{tool.icon}</span>
              <div class="min-w-0">
                <span class="block text-sm font-bold text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors">{tool.name}</span>
                <span class="block text-xs text-[var(--color-text-muted)] mt-0.5">{tool.desc}</span>
              </div>
            </a>
          ))}
        </div>
        <div class="mt-6 text-center">
          <a href="/tools/" class="text-sm font-semibold text-indigo-500 hover:text-indigo-400 transition-colors inline-flex items-center gap-1">
            See all 7 tools
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>
      </div>
    </section>

    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 py-4">
      <AdSlot slot="bottom" />
    </div>

    <!-- ══════════════════════════════════════════════
         FAQ
    ══════════════════════════════════════════════ -->
    <section class="py-16 bg-[var(--color-surface)]">
      <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
        <h2 data-scroll="fade-up" class="mb-10 text-center text-2xl font-black text-[var(--color-text)] sm:text-3xl">Frequently Asked Questions</h2>
        <div data-scroll="stagger-up" class="space-y-3">
          {homeFaqs.map((faq, i) => (
            <details class="group rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg)] transition-all hover:border-indigo-200 dark:hover:border-indigo-800/50 overflow-hidden">
              <summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-5 py-4 font-bold text-[var(--color-text)] select-none">
                <span class="text-sm leading-snug">{faq.q}</span>
                <span class="flex-shrink-0 flex h-6 w-6 items-center justify-center rounded-full border border-[var(--color-border)] text-[var(--color-text-muted)] text-sm transition-all group-open:rotate-45 group-open:border-indigo-400 group-open:text-indigo-500">
                  +
                </span>
              </summary>
              <div class="border-t border-[var(--color-border)] px-5 pb-5 pt-4">
                <p class="text-sm leading-relaxed text-[var(--color-text-muted)]">{faq.a}</p>
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>
