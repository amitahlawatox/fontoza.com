---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import Breadcrumbs from '../../components/layout/Breadcrumbs.astro';
import AdSlot from '../../components/ads/AdSlot.astro';
import WordCounter from '../../components/tools/WordCounter';
import { generateToolMeta } from '../../lib/seo/meta';
import { webApplicationSchema } from '../../lib/seo/schema';

const meta = generateToolMeta({
  id: 'word-counter',
  name: 'Word Counter',
  description: 'Count words, characters, sentences, paragraphs, and reading time in your text.',
});

const schema = webApplicationSchema({
  name: 'Word Counter — Fontoza',
  description: meta.description,
  url: meta.canonical,
});
---

<Layout
  title={meta.title}
  description={meta.description}
  canonical={meta.canonical}
  ogImage={meta.ogImage}
  schema={schema}
>
  <Header />
  <main id="main-content" class="mx-auto max-w-3xl px-4 py-10 sm:px-6 lg:px-8">
    <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Tools', href: '/tools' }, { label: 'Word Counter' }]} />

    <h1 class="mb-2 text-3xl font-bold tracking-tight text-[var(--color-text)]">Word Counter</h1>
    <p class="mb-8 text-[var(--color-text-muted)]">
      Paste or type your text to instantly count words, characters (with and without spaces), sentences, paragraphs, and estimated reading time.
    </p>

    <WordCounter client:load />

    <AdSlot slot="bottom" />

    <section class="mt-12 space-y-4 text-sm text-[var(--color-text-muted)]">
      <h2 class="text-xl font-bold text-[var(--color-text)]">About This Tool</h2>
      <p>The Fontoza Word Counter is a free, instant text analysis tool. It works entirely in your browser — nothing is sent to a server. Counts update in real time as you type or paste.</p>
      <p>Use it for checking blog post length, fitting social media character limits, estimating reading time, or analyzing essays. The reading time estimate assumes an average reading speed of 200 words per minute.</p>
    </section>
  </main>
  <Footer />
</Layout>
