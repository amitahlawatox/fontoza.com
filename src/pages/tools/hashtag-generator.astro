---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import Breadcrumbs from '../../components/layout/Breadcrumbs.astro';
import AdSlot from '../../components/ads/AdSlot.astro';
import HashtagGenerator from '../../components/tools/HashtagGenerator';
import { generateToolMeta } from '../../lib/seo/meta';
import { webApplicationSchema } from '../../lib/seo/schema';

const meta = generateToolMeta({
  id: 'hashtag-generator',
  name: 'Hashtag Generator',
  description: 'Input a topic and get 30 relevant hashtags grouped by reach size: mega, macro, and micro.',
});

const schema = webApplicationSchema({
  name: 'Hashtag Generator — Fontoza',
  description: meta.description,
  url: meta.canonical,
});
---

<Layout
  title={meta.title}
  description={meta.description}
  canonical={meta.canonical}
  ogImage={meta.ogImage}
  schema={schema}
>
  <Header />
  <main id="main-content" class="mx-auto max-w-3xl px-4 py-10 sm:px-6 lg:px-8">
    <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Tools', href: '/tools' }, { label: 'Hashtag Generator' }]} />

    <h1 class="mb-2 text-3xl font-bold tracking-tight text-[var(--color-text)]">Hashtag Generator</h1>
    <p class="mb-8 text-[var(--color-text-muted)]">
      Enter your topic or niche to get 30 relevant hashtags, organized by reach (mega, macro, and micro). A balanced mix of all three gives the best visibility on Instagram and TikTok.
    </p>

    <HashtagGenerator client:load />

    <AdSlot slot="bottom" />

    <section class="mt-12 space-y-4 text-sm text-[var(--color-text-muted)]">
      <h2 class="text-xl font-bold text-[var(--color-text)]">Hashtag Strategy Guide</h2>
      <ul class="space-y-2 list-disc list-inside">
        <li><strong class="text-[var(--color-text)]">Mega hashtags</strong> (1M+ posts): High exposure but very competitive. Use 3–5 per post.</li>
        <li><strong class="text-[var(--color-text)]">Macro hashtags</strong> (100K–1M posts): Good reach with manageable competition. Use 5–10 per post.</li>
        <li><strong class="text-[var(--color-text)]">Micro hashtags</strong> (under 100K posts): Targeted audience, stays visible longer. Use 10–15 per post.</li>
        <li>Instagram allows up to 30 hashtags per post. Using a mix of all three tiers is the proven approach.</li>
        <li>Avoid banned or overused hashtags — they can suppress your post visibility.</li>
        <li>Rotate your hashtag sets to avoid being flagged as spam.</li>
      </ul>
    </section>
  </main>
  <Footer />
</Layout>
