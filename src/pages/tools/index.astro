---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';

const tools = [
  {
    id: 'word-counter',
    name: 'Word Counter',
    description: 'Count words, characters, sentences, and paragraphs in real time. Perfect for essays, tweets, and captions.',
    icon: '📝',
    color: 'from-blue-500 to-cyan-500',
    badge: 'Writing',
    href: '/tools/word-counter/',
  },
  {
    id: 'character-counter',
    name: 'Character Counter',
    description: 'Track character count against platform limits — Instagram, Twitter, TikTok, and more.',
    icon: '🔢',
    color: 'from-violet-500 to-purple-500',
    badge: 'Social',
    href: '/tools/character-counter/',
  },
  {
    id: 'text-case-converter',
    name: 'Text Case Converter',
    description: 'Switch between UPPERCASE, lowercase, Title Case, camelCase, snake_case, and more in one click.',
    icon: '🔡',
    color: 'from-orange-500 to-amber-500',
    badge: 'Utility',
    href: '/tools/text-case-converter/',
  },
  {
    id: 'password-generator',
    name: 'Password Generator',
    description: 'Generate cryptographically secure passwords with custom length and character sets. 100% client-side.',
    icon: '🔐',
    color: 'from-green-500 to-emerald-500',
    badge: 'Security',
    href: '/tools/password-generator/',
  },
  {
    id: 'bio-generator',
    name: 'Bio Generator',
    description: 'Create standout Instagram and TikTok bios from your keywords. AI-inspired templates for every vibe.',
    icon: '✨',
    color: 'from-pink-500 to-rose-500',
    badge: 'Social',
    href: '/tools/bio-generator/',
  },
  {
    id: 'hashtag-generator',
    name: 'Hashtag Generator',
    description: 'Get 30 relevant, grouped hashtags for any topic — sized small, medium, and large for maximum reach.',
    icon: '#️⃣',
    color: 'from-indigo-500 to-blue-500',
    badge: 'Social',
    href: '/tools/hashtag-generator/',
  },
  {
    id: 'lorem-ipsum-generator',
    name: 'Lorem Ipsum Generator',
    description: 'Generate placeholder text in plain text, HTML, or Markdown format. Custom paragraphs, sentences, or words.',
    icon: '📄',
    color: 'from-teal-500 to-cyan-500',
    badge: 'Dev',
    href: '/tools/lorem-ipsum-generator/',
  },
];
---

<Layout
  title="Free Online Tools — Word Counter, Password Generator & More | Fontoza"
  description="Free browser-based tools from Fontoza: Word Counter, Character Counter, Text Case Converter, Password Generator, Bio Generator, Hashtag Generator, and Lorem Ipsum. No sign-up required."
  canonical="https://fontoza.com/tools/"
  ogImage="https://fontoza.com/og-image.png"
>
  <Header />

  <main id="main-content">
    <!-- Hero -->
    <section class="relative overflow-hidden py-14 bg-gradient-to-b from-purple-50/60 via-indigo-50/20 to-transparent dark:from-purple-950/20 dark:via-indigo-950/10 dark:to-transparent">
      <!-- Decorative blobs -->
      <div class="pointer-events-none absolute -top-20 right-0 w-80 h-80 rounded-full bg-gradient-to-br from-purple-400/10 to-pink-400/10 blur-3xl" aria-hidden="true"></div>

      <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center relative">
        <span class="mb-4 inline-flex items-center gap-2 rounded-full bg-purple-100 px-4 py-1.5 text-xs font-bold tracking-wide text-purple-700 dark:bg-purple-900/40 dark:text-purple-300 uppercase animate-fade-up">
          🛠️ {tools.length} Free Tools
        </span>

        <h1 class="mt-3 text-3xl font-black tracking-tight text-[var(--color-text)] sm:text-4xl lg:text-5xl animate-fade-up-delay-1">
          Free
          <span class="bg-gradient-to-r from-purple-500 to-pink-500 bg-clip-text text-transparent"> Online Tools</span>
        </h1>
        <p class="mt-4 mx-auto max-w-2xl text-base text-[var(--color-text-muted)] sm:text-lg animate-fade-up-delay-2">
          Browser-based utilities that run entirely on your device. No sign-up, no data collection, always free.
        </p>
      </div>
    </section>

    <!-- Tools Grid -->
    <section class="py-10 pb-20">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <div class="stagger-children grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {tools.map((tool) => (
            <a
              href={tool.href}
              class="card-hover group relative flex flex-col rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg)] p-6 overflow-hidden transition-all"
            >
              <!-- Gradient background on hover -->
              <div class="pointer-events-none absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300 rounded-2xl" style={`background: radial-gradient(ellipse at top right, rgba(99,102,241,0.06) 0%, transparent 70%)`} aria-hidden="true"></div>

              <!-- Icon with gradient background -->
              <div class={`mb-4 flex h-12 w-12 items-center justify-center rounded-2xl bg-gradient-to-br ${tool.color} text-2xl shadow-lg`}>
                {tool.icon}
              </div>

              <!-- Badge -->
              <span class="mb-3 inline-block w-fit rounded-full bg-[var(--color-surface)] px-2.5 py-0.5 text-xs font-semibold text-[var(--color-text-muted)]">
                {tool.badge}
              </span>

              <!-- Content -->
              <h2 class="mb-2 text-lg font-bold text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors">
                {tool.name}
              </h2>
              <p class="flex-1 text-sm leading-relaxed text-[var(--color-text-muted)]">
                {tool.description}
              </p>

              <!-- CTA -->
              <div class="mt-5 flex items-center gap-1.5 text-sm font-semibold text-indigo-500 group-hover:gap-2.5 transition-all">
                Open tool
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <line x1="5" y1="12" x2="19" y2="12" />
                  <polyline points="12 5 19 12 12 19" />
                </svg>
              </div>
            </a>
          ))}
        </div>

        <!-- Back to font generator -->
        <div class="mt-14 text-center">
          <p class="mb-4 text-[var(--color-text-muted)] text-sm">Looking for fancy text instead?</p>
          <a
            href="/"
            class="inline-flex items-center gap-2 rounded-2xl bg-gradient-to-r from-indigo-600 to-purple-600 px-8 py-3.5 text-sm font-bold text-white shadow-lg shadow-indigo-500/25 transition-all hover:shadow-indigo-500/40 hover:scale-[1.02] active:scale-95"
          >
            ✨ Open Fancy Text Generator
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
