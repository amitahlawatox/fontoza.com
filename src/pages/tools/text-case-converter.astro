---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import Breadcrumbs from '../../components/layout/Breadcrumbs.astro';
import AdSlot from '../../components/ads/AdSlot.astro';
import TextCaseConverter from '../../components/tools/TextCaseConverter';
import { generateToolMeta } from '../../lib/seo/meta';
import { webApplicationSchema } from '../../lib/seo/schema';

const meta = generateToolMeta({
  id: 'text-case-converter',
  name: 'Text Case Converter',
  description: 'Convert text to uppercase, lowercase, title case, sentence case, alternating case, camelCase, and snake_case instantly.',
});

const schema = webApplicationSchema({
  name: 'Text Case Converter — Fontoza',
  description: meta.description,
  url: meta.canonical,
});
---

<Layout
  title={meta.title}
  description={meta.description}
  canonical={meta.canonical}
  ogImage={meta.ogImage}
  schema={schema}
>
  <Header />
  <main id="main-content" class="mx-auto max-w-3xl px-4 py-10 sm:px-6 lg:px-8">
    <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Tools', href: '/tools' }, { label: 'Text Case Converter' }]} />

    <h1 class="mb-2 text-3xl font-bold tracking-tight text-[var(--color-text)]">Text Case Converter</h1>
    <p class="mb-8 text-[var(--color-text-muted)]">
      Instantly convert your text to UPPERCASE, lowercase, Title Case, Sentence case, aLtErNaTiNg, camelCase, or snake_case.
    </p>

    <TextCaseConverter client:load />

    <AdSlot slot="bottom" />

    <section class="mt-12 space-y-4 text-sm text-[var(--color-text-muted)]">
      <h2 class="text-xl font-bold text-[var(--color-text)]">When to Use Each Case</h2>
      <ul class="space-y-2 list-disc list-inside">
        <li><strong class="text-[var(--color-text)]">UPPERCASE:</strong> Headlines, emphasis, acronyms, shouting on the internet</li>
        <li><strong class="text-[var(--color-text)]">lowercase:</strong> Casual writing, social media captions, modern minimalist style</li>
        <li><strong class="text-[var(--color-text)]">Title Case:</strong> Titles, headings, product names, proper formatting</li>
        <li><strong class="text-[var(--color-text)]">Sentence case:</strong> Standard prose, emails, articles, most body text</li>
        <li><strong class="text-[var(--color-text)]">aLtErNaTiNg:</strong> Sarcastic tone, memes, ironic commentary</li>
        <li><strong class="text-[var(--color-text)]">camelCase:</strong> JavaScript variables, API keys, function names</li>
        <li><strong class="text-[var(--color-text)]">snake_case:</strong> Python variables, database columns, file names</li>
      </ul>
    </section>
  </main>
  <Footer />
</Layout>
