---
import Layout from '../layouts/Layout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';

const meta = {
  title: 'About Fontoza — Free Fancy Text Generator',
  description: 'Learn about Fontoza, the free Unicode fancy text generator. Zero cookies, zero tracking, no sign-up. Just 400+ font styles that copy and paste anywhere.',
  canonical: 'https://fontoza.com/about/',
  ogImage: 'https://fontoza.com/og-image.png',
};

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Fontoza',
  url: 'https://fontoza.com',
  description: 'Free fancy text generator with 400+ Unicode font styles.',
  contactPoint: { '@type': 'ContactPoint', email: 'contact@fontoza.com', contactType: 'customer support' },
};
---

<Layout
  title={meta.title}
  description={meta.description}
  canonical={meta.canonical}
  ogImage={meta.ogImage}
  schema={schema}
>
  <Header />
  <main id="main-content" class="mx-auto max-w-3xl px-4 py-12 sm:px-6 lg:px-8">
    <h1 class="mb-6 text-3xl font-bold tracking-tight text-[var(--color-text)]">About Fontoza</h1>

    <div class="space-y-8 text-sm leading-relaxed text-[var(--color-text-muted)]">

      <section>
        <h2 class="mb-3 text-xl font-bold text-[var(--color-text)]">What Is Fontoza?</h2>
        <p>
          Fontoza is a free, browser-based fancy text generator that converts your regular text into 400+ Unicode font styles — cursive, bold, gothic, italic, vaporwave, zalgo, geometric, and many more. Every style you see is built from real Unicode characters from the Mathematical Script, Fraktur, Double-Struck, and enclosed alphanumeric blocks.
        </p>
        <p class="mt-3">
          Because the output is standard Unicode — not images, not custom fonts, not HTML — it pastes perfectly into Instagram bios, TikTok profiles, Discord usernames, Twitter display names, Facebook posts, WhatsApp messages, and virtually any other platform that accepts text.
        </p>
      </section>

      <section>
        <h2 class="mb-3 text-xl font-bold text-[var(--color-text)]">Who Built It?</h2>
        <p>
          Fontoza was built for creators, students, businesses, and anyone who wants their text to stand out without downloading software or learning typography. The project is maintained as a free tool for the community.
        </p>
      </section>

      <section>
        <h2 class="mb-3 text-xl font-bold text-[var(--color-text)]">Our Privacy Commitment</h2>
        <p>
          Fontoza collects <strong class="text-[var(--color-text)]">no personal data</strong> and sets <strong class="text-[var(--color-text)]">no tracking cookies</strong>. The tool runs entirely in your browser. The text you type never leaves your device — it is processed locally by JavaScript and never sent to any server.
        </p>
        <p class="mt-3">
          The only data stored on your device is your last-typed text, saved to <code class="rounded bg-[var(--color-surface)] px-1 font-mono text-xs">localStorage</code> so you do not lose your work if you navigate away. This preference is stored locally and is never transmitted.
        </p>
        <p class="mt-3">
          Fontoza uses Vercel Analytics (privacy-first, no personal data collected) and may serve Google AdSense advertisements, which uses its own cookie policies as described in our <a href="/privacy" class="text-indigo-500 hover:underline">Privacy Policy</a>.
        </p>
      </section>

      <section>
        <h2 class="mb-3 text-xl font-bold text-[var(--color-text)]">Tools We Offer</h2>
        <ul class="space-y-2 list-disc list-inside">
          <li><a href="/" class="text-indigo-500 hover:underline">Fancy Text Generator</a> — 400+ Unicode font styles with live preview</li>
          <li><a href="/tools/word-counter" class="text-indigo-500 hover:underline">Word Counter</a> — Count words, characters, sentences, and paragraphs</li>
          <li><a href="/tools/character-counter" class="text-indigo-500 hover:underline">Character Counter</a> — Track character counts against platform limits</li>
          <li><a href="/tools/text-case-converter" class="text-indigo-500 hover:underline">Text Case Converter</a> — UPPERCASE, lowercase, Title Case, camelCase, and more</li>
          <li><a href="/tools/password-generator" class="text-indigo-500 hover:underline">Password Generator</a> — Cryptographically secure passwords, generated client-side</li>
          <li><a href="/tools/bio-generator" class="text-indigo-500 hover:underline">Bio Generator</a> — Instagram and TikTok bio templates from your keywords</li>
          <li><a href="/tools/hashtag-generator" class="text-indigo-500 hover:underline">Hashtag Generator</a> — 30 relevant hashtags grouped by size</li>
          <li><a href="/tools/lorem-ipsum-generator" class="text-indigo-500 hover:underline">Lorem Ipsum Generator</a> — Placeholder text in text, HTML, or Markdown</li>
        </ul>
      </section>

      <section>
        <h2 class="mb-3 text-xl font-bold text-[var(--color-text)]">Contact</h2>
        <p>
          For business inquiries, partnership requests, or feedback, please reach out to us at:
          <a href="mailto:contact@fontoza.com" class="ml-1 text-indigo-500 hover:underline">contact@fontoza.com</a>
        </p>
        <p class="mt-3">
          We aim to respond within 2–3 business days.
        </p>
      </section>

    </div>
  </main>
  <Footer />
</Layout>
