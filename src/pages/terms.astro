---
import Layout from '../layouts/Layout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';

const meta = {
  title: 'Terms of Service — Fontoza',
  description: 'Fontoza Terms of Service. Free text generator tool — terms covering use of service, intellectual property, and disclaimers.',
  canonical: 'https://fontoza.com/terms/',
  ogImage: 'https://fontoza.com/og-image.png',
};
const schema = { '@context': 'https://schema.org', '@type': 'WebPage', name: 'Terms of Service', url: 'https://fontoza.com/terms/', publisher: { '@type': 'Organization', name: 'Fontoza', url: 'https://fontoza.com' } };
---

<Layout
  title={meta.title}
  description={meta.description}
  canonical={meta.canonical}
  ogImage={meta.ogImage}
  schema={schema}
>
  <Header />
  <main id="main-content" class="mx-auto max-w-3xl px-4 py-12 sm:px-6 lg:px-8">
    <h1 class="mb-2 text-3xl font-bold tracking-tight text-[var(--color-text)]">Terms of Service</h1>
    <p class="mb-8 text-sm text-[var(--color-text-muted)]">Last updated: June 10, 2026</p>

    <div class="space-y-8 text-sm leading-relaxed text-[var(--color-text-muted)]">

      <section>
        <h2 class="mb-3 text-xl font-bold text-[var(--color-text)]">1. Acceptance of Terms</h2>
        <p>
          By accessing or using the Fontoza website at fontoza.com ("Service"), you agree to be bound by these Terms of Service ("Terms"). If you do not agree to these Terms, please do not use the Service.
        </p>
        <p class="mt-3">
          We reserve the right to modify these Terms at any time. Changes will be effective immediately upon posting. Your continued use of the Service following any changes constitutes acceptance of those changes.
        </p>
      </section>

      <section>
        <h2 class="mb-3 text-xl font-bold text-[var(--color-text)]">2. Description of Service</h2>
        <p>
          Fontoza provides a free, browser-based text transformation tool that converts input text into various Unicode character styles. The Service also includes utility tools such as a word counter, character counter, text case converter, password generator, bio generator, hashtag generator, and Lorem Ipsum generator.
        </p>
        <p class="mt-3">
          All transformation processing occurs client-side in your browser. No account registration is required to use the core features.
        </p>
      </section>

      <section>
        <h2 class="mb-3 text-xl font-bold text-[var(--color-text)]">3. Use of the Service</h2>
        <h3 class="mb-2 font-semibold text-[var(--color-text)]">3.1 Permitted Use</h3>
        <p>
          You may use the Service for personal, commercial, and educational purposes. You may copy and use the Unicode text generated by the Service without restriction — the Unicode characters themselves are part of the public Unicode standard and are not proprietary.
        </p>

        <h3 class="mt-4 mb-2 font-semibold text-[var(--color-text)]">3.2 Prohibited Use</h3>
        <p>You agree not to use the Service to:</p>
        <ul class="mt-2 list-disc list-inside space-y-1">
          <li>Engage in any activity that is illegal under applicable law</li>
          <li>Generate or distribute spam, harassment, or abusive content</li>
          <li>Attempt to reverse-engineer, scrape, or systematically extract data from the Service in a manner that burdens our infrastructure</li>
          <li>Circumvent any security or access controls on the Service</li>
          <li>Use the Service in any way that violates the rights of others</li>
          <li>Attempt to interfere with the proper functioning of the Service</li>
        </ul>

        <h3 class="mt-4 mb-2 font-semibold text-[var(--color-text)]">3.3 User Responsibility</h3>
        <p>
          You are solely responsible for the content you create using the Service and for any consequences of sharing that content on third-party platforms. Fontoza is not responsible for how others receive or react to text you generate and share.
        </p>
      </section>

      <section>
        <h2 class="mb-3 text-xl font-bold text-[var(--color-text)]">4. Intellectual Property</h2>
        <h3 class="mb-2 font-semibold text-[var(--color-text)]">4.1 Unicode Characters</h3>
        <p>
          The Unicode characters generated by this Service are part of the Unicode Standard, an open international standard maintained by the Unicode Consortium. Unicode characters are not proprietary and are not owned by Fontoza. You may freely use any text generated by the Service.
        </p>

        <h3 class="mt-4 mb-2 font-semibold text-[var(--color-text)]">4.2 Fontoza Intellectual Property</h3>
        <p>
          The Fontoza name, logo, website design, code, and written content (excluding the Unicode characters themselves) are the intellectual property of Fontoza. You may not reproduce, distribute, or create derivative works from these materials without express written permission, except as permitted by applicable fair use provisions.
        </p>

        <h3 class="mt-4 mb-2 font-semibold text-[var(--color-text)]">4.3 Your Content</h3>
        <p>
          You retain ownership of any text you input into the Service. As noted in our Privacy Policy, input text is processed locally and is not transmitted to or stored on our servers. We make no claim to your input content.
        </p>
      </section>

      <section>
        <h2 class="mb-3 text-xl font-bold text-[var(--color-text)]">5. Disclaimers and Warranties</h2>
        <p>
          THE SERVICE IS PROVIDED "AS IS" AND "AS AVAILABLE" WITHOUT ANY WARRANTIES OF ANY KIND, EXPRESS OR IMPLIED, INCLUDING BUT NOT LIMITED TO WARRANTIES OF MERCHANTABILITY, FITNESS FOR A PARTICULAR PURPOSE, OR NON-INFRINGEMENT.
        </p>
        <p class="mt-3">
          We do not warrant that:
        </p>
        <ul class="mt-2 list-disc list-inside space-y-1">
          <li>The Service will be uninterrupted, timely, secure, or error-free</li>
          <li>The results obtained from using the Service will be accurate or reliable</li>
          <li>Unicode characters generated will render identically on all platforms and devices</li>
          <li>Generated passwords will meet the security requirements of any specific system</li>
        </ul>
      </section>

      <section>
        <h2 class="mb-3 text-xl font-bold text-[var(--color-text)]">6. Limitation of Liability</h2>
        <p>
          TO THE MAXIMUM EXTENT PERMITTED BY LAW, FONTOZA SHALL NOT BE LIABLE FOR ANY INDIRECT, INCIDENTAL, SPECIAL, CONSEQUENTIAL, OR PUNITIVE DAMAGES, INCLUDING LOSS OF PROFITS, DATA, OR GOODWILL, ARISING FROM OR RELATED TO YOUR USE OF THE SERVICE.
        </p>
        <p class="mt-3">
          Our total liability for any claims arising from these Terms or use of the Service shall not exceed the amount you paid us in the twelve months prior to the claim (which, since the Service is free, is zero dollars).
        </p>
      </section>

      <section>
        <h2 class="mb-3 text-xl font-bold text-[var(--color-text)]">7. Third-Party Services</h2>
        <p>
          The Service may display advertisements from Google AdSense and use Vercel for hosting and analytics. These third-party services are governed by their own terms of service and privacy policies. Fontoza is not responsible for the content, accuracy, or practices of these third-party services.
        </p>
      </section>

      <section>
        <h2 class="mb-3 text-xl font-bold text-[var(--color-text)]">8. Governing Law and Dispute Resolution</h2>
        <p>
          These Terms are governed by and construed in accordance with applicable law. We encourage resolution of disputes through good-faith negotiation — please contact us at <a href="mailto:contact@fontoza.com" class="text-indigo-500 hover:underline">contact@fontoza.com</a> before pursuing any formal legal action.
        </p>
        <p class="mt-3">
          If you are located in the European Union, you may use the EU's Online Dispute Resolution platform at <a href="https://ec.europa.eu/consumers/odr" class="text-indigo-500 hover:underline" target="_blank" rel="noopener noreferrer">ec.europa.eu/consumers/odr</a>.
        </p>
      </section>

      <section>
        <h2 class="mb-3 text-xl font-bold text-[var(--color-text)]">8a. DMCA and Intellectual Property Claims</h2>
        <p>
          If you believe that content on Fontoza infringes your copyright or other intellectual property rights, please send a written notice to <a href="mailto:contact@fontoza.com" class="text-indigo-500 hover:underline">contact@fontoza.com</a> with the following information:
        </p>
        <ul class="mt-2 list-disc list-inside space-y-1">
          <li>A description of the copyrighted work you claim has been infringed</li>
          <li>The URL or specific location of the allegedly infringing material</li>
          <li>Your contact information (name, address, phone number, email)</li>
          <li>A statement that you have a good faith belief that the use is not authorised</li>
          <li>A statement that the information in the notice is accurate and, under penalty of perjury, that you are the copyright owner or authorised to act on their behalf</li>
        </ul>
        <p class="mt-3">
          Note that Fontoza generates text client-side in the user's browser — we do not store or host user-generated content on our servers.
        </p>
      </section>

      <section>
        <h2 class="mb-3 text-xl font-bold text-[var(--color-text)]">9. Severability</h2>
        <p>
          If any provision of these Terms is found to be unenforceable or invalid, that provision shall be limited or eliminated to the minimum extent necessary, and the remaining provisions shall remain in full force and effect.
        </p>
      </section>

      <section>
        <h2 class="mb-3 text-xl font-bold text-[var(--color-text)]">10. Contact</h2>
        <p>
          If you have questions about these Terms, please contact us at:
        </p>
        <p class="mt-2">
          Email: <a href="mailto:contact@fontoza.com" class="text-indigo-500 hover:underline">contact@fontoza.com</a>
        </p>
      </section>

    </div>
  </main>
  <Footer />
</Layout>
