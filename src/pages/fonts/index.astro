---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import FontConverter from '../../components/tool/FontConverter';
import { STYLES } from '../../lib/registry';
import type { StyleDefinition } from '../../lib/registry';
import { CATEGORIES } from '../../lib/categories';

function getDecoratorName(style: StyleDefinition): string | undefined {
  if (style.id.includes('strikethrough') || style.tags?.includes('strikethrough')) return 'strikethrough';
  if (style.id.includes('double-underline')) return 'doubleUnderline';
  if (style.id.includes('underline') && !style.id.includes('double')) return 'underline';
  if (style.id.includes('zalgo-light')) return 'zalgoLight';
  if (style.id.includes('zalgo-heavy')) return 'zalgoHeavy';
  if (style.id.includes('zalgo')) return 'zalgoMedium';
  if (style.id.includes('vaporwave')) return 'vaporwaveSpace';
  if (style.id.includes('hearts') || style.tags?.includes('hearts')) return 'hearts';
  if (style.id.includes('stars') || style.tags?.includes('stars')) return 'stars';
  if (style.id.includes('sparkles') || style.tags?.includes('sparkles')) return 'sparkles';
  if (style.id.includes('flowers') || style.tags?.includes('flowers')) return 'flowers';
  if (style.id.includes('crown') || style.tags?.includes('crown')) return 'crown';
  return undefined;
}

const serializedStyles = STYLES.map((style) => ({
  id: style.id,
  name: style.name,
  map: style.map as Record<string, string>,
  category: style.category,
  decorator: getDecoratorName(style),
}));
---

<Layout
  title="All Font Styles — 50+ Fancy Unicode Fonts | Fontoza"
  description="Browse all 50+ fancy Unicode font styles on Fontoza. Cursive, bold, gothic, italic, vaporwave, zalgo, geometric and more. Copy and paste anywhere."
  canonical="https://fontoza.com/fonts/"
  ogImage="https://fontoza.com/og-image.png"
>
  <Header />

  <main id="main-content">
    <!-- Hero -->
    <section class="relative overflow-hidden bg-gradient-to-b from-indigo-50/60 via-purple-50/20 to-transparent py-12 dark:from-indigo-950/20 dark:via-purple-950/10 dark:to-transparent">
      <!-- Decorative blobs -->
      <div class="pointer-events-none absolute -top-20 -right-20 w-72 h-72 rounded-full bg-gradient-to-br from-indigo-400/10 to-purple-400/10 blur-3xl" aria-hidden="true"></div>
      <div class="pointer-events-none absolute -bottom-10 -left-10 w-48 h-48 rounded-full bg-gradient-to-br from-pink-400/10 to-indigo-400/10 blur-3xl" aria-hidden="true"></div>

      <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 relative">
        <div class="mb-8 text-center animate-fade-up">
          <!-- Badge -->
          <span class="mb-4 inline-flex items-center gap-2 rounded-full bg-indigo-100 px-4 py-1.5 text-xs font-bold tracking-wide text-indigo-700 dark:bg-indigo-900/40 dark:text-indigo-300 uppercase">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            {STYLES.length}+ Unicode Font Styles
          </span>

          <h1 class="mt-3 text-3xl font-black tracking-tight text-[var(--color-text)] sm:text-4xl lg:text-5xl">
            All
            <span class="text-shimmer"> Font Styles</span>
          </h1>
          <p class="mt-4 mx-auto max-w-2xl text-base text-[var(--color-text-muted)] sm:text-lg">
            Type your text below. Every style updates instantly — click any card to copy.
          </p>
        </div>

        <!-- Font Converter -->
        <div class="animate-fade-up-delay-2">
          <FontConverter client:load styles={serializedStyles} />
        </div>
      </div>
    </section>

    <!-- Browse by Category -->
    <section class="py-16 bg-[var(--color-surface)]">
      <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
        <div class="mb-10 text-center">
          <h2 class="text-2xl font-bold text-[var(--color-text)] sm:text-3xl">Browse by Category</h2>
          <p class="mt-2 text-sm text-[var(--color-text-muted)]">Jump straight to the style family you want.</p>
        </div>
        <div class="stagger-children grid gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
          {CATEGORIES.map((cat) => (
            <a
              href={`/category/${cat.id}/`}
              class="card-hover group flex items-start gap-3 rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg)] p-5 transition-all"
            >
              <span class="text-2xl flex-shrink-0" aria-hidden="true">{cat.icon}</span>
              <div class="min-w-0">
                <span class="block font-semibold text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors truncate">
                  {cat.name}
                </span>
                <span class="mt-0.5 block text-xs text-[var(--color-text-muted)] line-clamp-2">
                  {cat.description}
                </span>
                <span class="mt-2 block text-xs font-medium text-indigo-500">
                  {cat.styleIds.length} styles →
                </span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
