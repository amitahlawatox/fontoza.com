---
const fontStyleLinks = [
  { label: 'Cursive Font', href: '/fonts/cursive-font/' },
  { label: 'Bold Text', href: '/fonts/bold-text/' },
  { label: 'Italic Font', href: '/fonts/italic-font/' },
  { label: 'Gothic Font', href: '/fonts/gothic-font/' },
  { label: 'Strikethrough Text', href: '/fonts/strikethrough-text/' },
  { label: 'Small Caps', href: '/fonts/small-caps/' },
  { label: 'Vaporwave Text', href: '/fonts/vaporwave-text/' },
  { label: 'Zalgo Text', href: '/fonts/zalgo-text/' },
];

const platformLinks = [
  { label: 'Instagram Fonts', href: '/platform/instagram-font-generator/' },
  { label: 'TikTok Fonts', href: '/platform/tiktok-font-generator/' },
  { label: 'Discord Fonts', href: '/platform/discord-font-generator/' },
  { label: 'Twitter / X Fonts', href: '/platform/twitter-font-generator/' },
  { label: 'Roblox Fonts', href: '/platform/roblox-font-generator/' },
  { label: 'Twitch Fonts', href: '/platform/twitch-font-generator/' },
  { label: 'LinkedIn Fonts', href: '/platform/linkedin-font-generator/' },
  { label: 'Telegram Fonts', href: '/platform/telegram-font-generator/' },
];

const toolLinks = [
  { label: 'Font Generator', href: '/' },
  { label: 'All Font Styles', href: '/fonts/' },
  { label: 'Word Counter', href: '/tools/word-counter/' },
  { label: 'Character Counter', href: '/tools/character-counter/' },
  { label: 'Password Generator', href: '/tools/password-generator/' },
  { label: 'All Tools', href: '/tools/' },
];

const companyLinks = [
  { label: 'About', href: '/about/' },
  { label: 'Privacy Policy', href: '/privacy/' },
  { label: 'Terms of Service', href: '/terms/' },
  { label: 'Accessibility', href: '/accessibility/' },
];

const year = new Date().getFullYear();
---

<footer class="border-t border-[var(--color-border)] bg-[var(--color-surface)] mt-16 relative overflow-hidden">
  <!-- Subtle gradient orbs -->
  <div class="pointer-events-none absolute -top-32 -right-32 w-64 h-64 rounded-full bg-gradient-to-br from-indigo-500/5 to-purple-500/5 blur-3xl"></div>
  <div class="pointer-events-none absolute -bottom-16 -left-16 w-48 h-48 rounded-full bg-gradient-to-br from-pink-500/5 to-indigo-500/5 blur-3xl"></div>

  <div class="mx-auto max-w-7xl px-4 py-14 sm:px-6 lg:px-8 relative">

    <!-- Top: logo + tagline + trust badges -->
    <div class="mb-12 flex flex-col items-start gap-4 sm:flex-row sm:items-start sm:justify-between">
      <div class="max-w-xs">
        <a
          href="/"
          aria-label="Fontoza home"
          class="inline-block text-2xl font-black tracking-tight"
        >
          <span class="bg-gradient-to-r from-indigo-500 via-purple-500 to-pink-500 bg-clip-text text-transparent">
            Fontoza
          </span>
        </a>
        <p class="mt-2 text-sm text-[var(--color-text-muted)] leading-relaxed">
          Copy &amp; paste fancy Unicode text in seconds. 400+ styles, zero tracking, always free.
        </p>

        <!-- Trust badges -->
        <div class="mt-4 flex flex-wrap gap-2">
          <span class="inline-flex items-center gap-1.5 rounded-full border border-green-200/50 bg-green-50/50 px-3 py-1 text-xs font-medium text-green-700 dark:border-green-800/50 dark:bg-green-900/20 dark:text-green-400">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            Privacy-First
          </span>
          <span class="inline-flex items-center gap-1.5 rounded-full border border-indigo-200/50 bg-indigo-50/50 px-3 py-1 text-xs font-medium text-indigo-700 dark:border-indigo-800/50 dark:bg-indigo-900/20 dark:text-indigo-400">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
            100% Free
          </span>
          <span class="inline-flex items-center gap-1.5 rounded-full border border-purple-200/50 bg-purple-50/50 px-3 py-1 text-xs font-medium text-purple-700 dark:border-purple-800/50 dark:bg-purple-900/20 dark:text-purple-400">
            ⚡ Instant
          </span>
        </div>
      </div>

      <!-- Unicode samples decorative -->
      <div class="hidden lg:flex items-center gap-4 text-2xl opacity-30 select-none" aria-hidden="true">
        <span class="animate-float">𝒻</span>
        <span class="animate-float-delay-1">𝔉</span>
        <span class="animate-float-delay-2">𝐅</span>
        <span class="animate-float-delay-3">Ｆ</span>
      </div>
    </div>

    <!-- 4-column link grid -->
    <div class="grid grid-cols-2 gap-8 sm:grid-cols-2 lg:grid-cols-4">
      <!-- Font Styles -->
      <div>
        <h3 class="mb-4 text-xs font-bold uppercase tracking-widest text-[var(--color-text)]">
          Font Styles
        </h3>
        <ul class="space-y-2.5">
          {fontStyleLinks.map(link => (
            <li>
              <a
                href={link.href}
                class="text-sm text-[var(--color-text-muted)] transition-all hover:text-[var(--color-accent)] hover:translate-x-0.5 inline-block"
              >
                {link.label}
              </a>
            </li>
          ))}
          <li>
            <a href="/fonts/" class="text-sm font-semibold text-indigo-500 transition-colors hover:text-indigo-400 inline-flex items-center gap-1">
              All 400+ styles
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
            </a>
          </li>
        </ul>
      </div>

      <!-- Platforms -->
      <div>
        <h3 class="mb-4 text-xs font-bold uppercase tracking-widest text-[var(--color-text)]">
          Platforms
        </h3>
        <ul class="space-y-2.5">
          {platformLinks.map(link => (
            <li>
              <a
                href={link.href}
                class="text-sm text-[var(--color-text-muted)] transition-all hover:text-[var(--color-accent)] hover:translate-x-0.5 inline-block"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Tools -->
      <div>
        <h3 class="mb-4 text-xs font-bold uppercase tracking-widest text-[var(--color-text)]">
          Tools
        </h3>
        <ul class="space-y-2.5">
          {toolLinks.map(link => (
            <li>
              <a
                href={link.href}
                class="text-sm text-[var(--color-text-muted)] transition-all hover:text-[var(--color-accent)] hover:translate-x-0.5 inline-block"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h3 class="mb-4 text-xs font-bold uppercase tracking-widest text-[var(--color-text)]">
          Company
        </h3>
        <ul class="space-y-2.5">
          {companyLinks.map(link => (
            <li>
              <a
                href={link.href}
                class="text-sm text-[var(--color-text-muted)] transition-all hover:text-[var(--color-accent)] hover:translate-x-0.5 inline-block"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>

        <!-- Contact -->
        <div class="mt-6">
          <h3 class="mb-3 text-xs font-bold uppercase tracking-widest text-[var(--color-text)]">Contact</h3>
          <a href="mailto:contact@fontoza.com" class="text-sm text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors break-all">
            contact@fontoza.com
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom copyright bar -->
    <div class="mt-12 flex flex-col items-center justify-between gap-3 border-t border-[var(--color-border)] pt-6 text-center sm:flex-row sm:text-left">
      <p class="text-xs text-[var(--color-text-muted)]">
        &copy; {year} Fontoza. All rights reserved.
      </p>
      <p class="text-xs text-[var(--color-text-muted)]">
        Made with ✨ for creators, students, and everyone in between.
      </p>
    </div>
  </div>
</footer>
