---
// Cookie consent banner — required for GDPR/ePrivacy compliance.
// Shown once per browser session until the user accepts or dismisses.
// Consent state is stored in localStorage under 'fontoza-cookie-consent'.
---

<div
  id="cookie-banner"
  role="dialog"
  aria-live="polite"
  aria-label="Cookie and privacy notice"
  class="fixed bottom-0 left-0 right-0 z-50 hidden border-t border-[var(--color-border)] bg-[var(--color-bg)]/95 backdrop-blur-sm shadow-lg"
>
  <div class="mx-auto max-w-5xl px-4 py-4 sm:px-6 lg:px-8">
    <div class="flex flex-col items-start gap-4 sm:flex-row sm:items-center sm:justify-between">
      <p class="text-sm text-[var(--color-text-muted)] leading-relaxed max-w-2xl">
        We use privacy-first analytics (no personal data) and may display Google ads which use cookies.
        Your text is <strong class="text-[var(--color-text)]">never sent to our servers</strong> — all processing happens in your browser.
        <a href="/privacy/" class="text-indigo-500 hover:underline ml-1">Privacy Policy</a>
      </p>
      <div class="flex flex-shrink-0 items-center gap-3">
        <button
          id="cookie-dismiss"
          class="rounded-lg px-4 py-2 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors border border-[var(--color-border)] hover:border-[var(--color-accent)]"
        >
          Dismiss
        </button>
        <button
          id="cookie-accept"
          class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-500 transition-colors"
        >
          Accept
        </button>
      </div>
    </div>
  </div>
</div>

<script is:inline>
  (function () {
    var CONSENT_KEY = 'fontoza-cookie-consent';
    var banner = document.getElementById('cookie-banner');
    if (!banner) return;

    try {
      if (!localStorage.getItem(CONSENT_KEY)) {
        banner.classList.remove('hidden');
      }
    } catch (e) {
      banner.classList.remove('hidden');
    }

    function hideBanner(value) {
      banner.classList.add('hidden');
      try { localStorage.setItem(CONSENT_KEY, value); } catch (e) {}
    }

    var acceptBtn = document.getElementById('cookie-accept');
    var dismissBtn = document.getElementById('cookie-dismiss');
    if (acceptBtn) acceptBtn.addEventListener('click', function () { hideBanner('accepted'); });
    if (dismissBtn) dismissBtn.addEventListener('click', function () { hideBanner('dismissed'); });
  })();
</script>
